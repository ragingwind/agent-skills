{
  "description": "Gate-keeping hooks — events.jsonl-authoritative pipeline gates (commit/PR/stop) plus worktree lifecycle setup and cleanup. Gates self-skip outside a pipeline branch; bypass with CLAUDE_EVENTS_HOOK_SKIP=1 (commit/PR/stop) or CLAUDE_COMMENT_AUDIT_SKIP=1 (comment audit).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/gate-keeping/pre-bash-commit-gate.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/gate-keeping/pre-bash-comment-audit.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/gate-keeping/pre-bash-pr-gate.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/gate-keeping/post-worktree-enter.sh\""
          }
        ]
      },
      {
        "matcher": "ExitWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/gate-keeping/post-worktree-exit.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/gate-keeping/stop-gate.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/gate-keeping/stop-notify.sh\""
          }
        ]
      }
    ]
  }
}
